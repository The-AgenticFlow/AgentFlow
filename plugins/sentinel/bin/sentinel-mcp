#!/usr/bin/env python3
"""Mock SENTINEL MCP Server for testing plugins."""

import json
import sys

MOCK_RESPONSES = {
    "run_tests": {"passed": 42, "failed": 0, "skipped": 2, "failures": [], "duration_ms": 12345},
    "run_linter": {"violations": [], "clean": True},
    "read_from_shared": {"content": "Mock content"},
    "write_eval": {"success": True},
    "write_final_review": {"success": True},
    "get_changed_files": {"files": []}
}

def handle_request(request):
    method = request.get("method", "")
    params = request.get("params", {})
    
    if method == "initialize":
        return {
            "protocolVersion": "2024-11-05",
            "capabilities": {"tools": {}},
            "serverInfo": {"name": "sentinel-mcp", "version": "1.0.0"}
        }
    elif method == "tools/list":
        return {
            "tools": [
                {"name": "run_tests", "description": "Run tests"},
                {"name": "run_linter", "description": "Run linter"},
                {"name": "read_from_shared", "description": "Read from shared"},
                {"name": "write_eval", "description": "Write evaluation"},
                {"name": "write_final_review", "description": "Write final review"},
                {"name": "get_changed_files", "description": "Get changed files"}
            ]
        }
    elif method == "tools/call":
        tool_name = params.get("name", "")
        if tool_name in MOCK_RESPONSES:
            return {"content": [{"type": "text", "text": json.dumps(MOCK_RESPONSES[tool_name])}]}
        return {"error": f"Unknown tool: {tool_name}"}
    return {"error": f"Unknown method: {method}"}

def main():
    for line in sys.stdin:
        line = line.strip()
        if not line:
            continue
        try:
            request = json.loads(line)
            response = {
                "jsonrpc": "2.0",
                "id": request.get("id"),
                "result": handle_request(request)
            }
            print(json.dumps(response), flush=True)
        except Exception as e:
            print(json.dumps({
                "jsonrpc": "2.0",
                "id": None,
                "error": {"code": -32603, "message": str(e)}
            }), flush=True)

if __name__ == "__main__":
    main()
