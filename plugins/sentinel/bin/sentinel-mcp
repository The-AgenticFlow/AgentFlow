#!/usr/bin/env python3
"""Mock SENTINEL MCP Server for testing plugins."""

import os
import sys

# Add scripts directory to path to find mcp_mock
sys.path.append(os.path.join(os.path.dirname(__file__), "../../../scripts"))
from mcp_mock import MCPMockServer

MOCK_RESPONSES = {
    "run_tests": {"passed": 42, "failed": 0, "skipped": 2, "failures": [], "duration_ms": 12345},
    "run_linter": {"violations": [], "clean": True},
    "read_from_shared": {"content": "Mock content"},
    "write_eval": {"success": True},
    "write_final_review": {"success": True},
    "get_changed_files": {"files": []}
}

TOOLS = [
    {"name": "run_tests", "description": "Run tests"},
    {"name": "run_linter", "description": "Run linter"},
    {"name": "read_from_shared", "description": "Read from shared"},
    {"name": "write_eval", "description": "Write evaluation"},
    {"name": "write_final_review", "description": "Write final review"},
    {"name": "get_changed_files", "description": "Get changed files"}
]

if __name__ == "__main__":
    server = MCPMockServer("sentinel-mcp", responses=MOCK_RESPONSES, tools=TOOLS)
    server.run()
