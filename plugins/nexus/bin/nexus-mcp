#!/usr/bin/env python3
"""Mock NEXUS MCP Server for testing plugins."""

import os
import sys

# Add scripts directory to path to find mcp_mock
sys.path.append(os.path.join(os.path.dirname(__file__), "../../../scripts"))
from mcp_mock import MCPMockServer

MOCK_RESPONSES = {
    "get_worker_slots": {
        "slots": [
            {"id": "forge-1", "status": "Idle"},
            {"id": "forge-2", "status": "Idle"}
        ]
    },
    "assign_worker": {"success": True},
    "get_command_gate": {"pending": []},
    "approve_command": {"success": True},
    "reject_command": {"success": True},
    "emit_event": {"success": True}
}

TOOLS = [
    {"name": "get_worker_slots", "description": "Get worker slots"},
    {"name": "assign_worker", "description": "Assign worker"},
    {"name": "get_command_gate", "description": "Get command gate"},
    {"name": "approve_command", "description": "Approve command"},
    {"name": "reject_command", "description": "Reject command"},
    {"name": "emit_event", "description": "Emit event"}
]

if __name__ == "__main__":
    server = MCPMockServer("nexus-mcp", responses=MOCK_RESPONSES, tools=TOOLS)
    server.run()
