#!/usr/bin/env python3
"""Mock NEXUS MCP Server for testing plugins."""

import json
import sys

MOCK_RESPONSES = {
    "get_worker_slots": {
        "slots": [
            {"id": "forge-1", "status": "Idle"},
            {"id": "forge-2", "status": "Idle"}
        ]
    },
    "assign_worker": {"success": True},
    "get_command_gate": {"pending": []},
    "approve_command": {"success": True},
    "reject_command": {"success": True},
    "emit_event": {"success": True}
}

def handle_request(request):
    method = request.get("method", "")
    params = request.get("params", {})
    
    if method == "initialize":
        return {
            "protocolVersion": "2024-11-05",
            "capabilities": {"tools": {}},
            "serverInfo": {"name": "nexus-mcp", "version": "1.0.0"}
        }
    elif method == "tools/list":
        return {
            "tools": [
                {"name": "get_worker_slots", "description": "Get worker slots"},
                {"name": "assign_worker", "description": "Assign worker"},
                {"name": "get_command_gate", "description": "Get command gate"},
                {"name": "approve_command", "description": "Approve command"},
                {"name": "reject_command", "description": "Reject command"},
                {"name": "emit_event", "description": "Emit event"}
            ]
        }
    elif method == "tools/call":
        tool_name = params.get("name", "")
        if tool_name in MOCK_RESPONSES:
            return {"content": [{"type": "text", "text": json.dumps(MOCK_RESPONSES[tool_name])}]}
        return {"error": f"Unknown tool: {tool_name}"}
    return {"error": f"Unknown method: {method}"}

def main():
    for line in sys.stdin:
        line = line.strip()
        if not line:
            continue
        try:
            request = json.loads(line)
            response = {
                "jsonrpc": "2.0",
                "id": request.get("id"),
                "result": handle_request(request)
            }
            print(json.dumps(response), flush=True)
        except Exception as e:
            print(json.dumps({
                "jsonrpc": "2.0",
                "id": None,
                "error": {"code": -32603, "message": str(e)}
            }), flush=True)

if __name__ == "__main__":
    main()
