#!/usr/bin/env python3
"""Mock LORE MCP Server for testing plugins."""

import json
import sys

MOCK_RESPONSES = {
    "get_merged_prs": {"prs": []},
    "get_pr_details": {"number": 47, "title": "Mock PR", "body": "Mock body", "files": [], "labels": []},
    "update_file": {"success": True, "commit_sha": "abc123"},
    "read_changelog": {"content": "# Changelog\n\n## [Unreleased]\n"},
    "update_changelog": {"success": True, "commit_sha": "abc123"}
}

def handle_request(request):
    method = request.get("method", "")
    params = request.get("params", {})
    
    if method == "initialize":
        return {
            "protocolVersion": "2024-11-05",
            "capabilities": {"tools": {}},
            "serverInfo": {"name": "lore-mcp", "version": "1.0.0"}
        }
    elif method == "tools/list":
        return {
            "tools": [
                {"name": "get_merged_prs", "description": "Get merged PRs"},
                {"name": "get_pr_details", "description": "Get PR details"},
                {"name": "update_file", "description": "Update file"},
                {"name": "read_changelog", "description": "Read changelog"},
                {"name": "update_changelog", "description": "Update changelog"}
            ]
        }
    elif method == "tools/call":
        tool_name = params.get("name", "")
        if tool_name in MOCK_RESPONSES:
            return {"content": [{"type": "text", "text": json.dumps(MOCK_RESPONSES[tool_name])}]}
        return {"error": f"Unknown tool: {tool_name}"}
    return {"error": f"Unknown method: {method}"}

def main():
    for line in sys.stdin:
        line = line.strip()
        if not line:
            continue
        try:
            request = json.loads(line)
            response = {
                "jsonrpc": "2.0",
                "id": request.get("id"),
                "result": handle_request(request)
            }
            print(json.dumps(response), flush=True)
        except Exception as e:
            print(json.dumps({
                "jsonrpc": "2.0",
                "id": None,
                "error": {"code": -32603, "message": str(e)}
            }), flush=True)

if __name__ == "__main__":
    main()
