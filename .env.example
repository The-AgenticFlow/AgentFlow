# LLM Configuration
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub Configuration
GITHUB_REPOSITORY=owner/repo
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here
# GITHUB_TOKEN=your_github_pat_here
GITHUB_MCP_CMD="npx -y @modelcontextprotocol/server-github"

# Pair Harness E2E
# Optional shared checkout/workdir for real/E2E agent tests.
# Point this at a clone/check-out you want to watch live while the agents run.
AGENT_TEST_WORKDIR=/absolute/path/to/Soft-Dev
REDIS_URL=redis://localhost:6379
REPO_PATH=/absolute/path/to/Soft-Dev

# Logging
RUST_LOG=info,agent_team=debug,pocketflow_core=debug
