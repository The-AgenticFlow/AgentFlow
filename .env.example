# LLM Configuration
# Provider options: anthropic, gemini, openai, fallback (default)
# "fallback" automatically tries providers in order set by LLM_FALLBACK
LLM_PROVIDER=fallback

# Fallback order (comma-separated, tried in order when provider fails/times out)
# Default: anthropic,gemini,openai
LLM_FALLBACK=anthropic,gemini

# Timeout for each provider (seconds)
LLM_TIMEOUT_SECS=60

# Anthropic (Claude) Configuration
# claude-haiku-4-5-20251001 is the cheapest model, ideal for orchestration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# Claude CLI Configuration
# Path to Claude CLI binary. REQUIRED for Forge workers to spawn Claude Code processes.
# Find your path with: which claude
# If not set, defaults to "claude" (expects it in PATH)
# Example: CLAUDE_PATH=/usr/local/bin/claude
# Example: CLAUDE_PATH=/home/user/.nvm/versions/node/v24.14.1/bin/claude
CLAUDE_PATH=claude

# GitHub Configuration
GITHUB_REPOSITORY=owner/repo
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here
GITHUB_MCP_CMD="npx -y @modelcontextprotocol/server-github"

# Logging
RUST_LOG=info,agent_team=debug,pocketflow_core=debug
